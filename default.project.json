{
  "name": "Multi Tower Kit",
  "emitLegacyScripts": false,
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$ignoreUnknownInstances": true,
      "Framework": {
        "$path": "src/Framework"
      },
      "ChangeLighting": {
        "$path": "src/assets/ChangeLighting.rbxm"
      },
      "DamageEvent": {
        "$path": "src/assets/DamageEvent.rbxm"
      },
      "ResetEffectGui": {
        "$path": "src/assets/ResetEffectGui.rbxm"
      },
      "src": {
        "$className": "Folder",
        "client": {
          "$path": "src/client"
        },
        "server": {
          "$path": "src/server"
        },
        "shared": {
          "$path": "src/shared"
        }
      },
      "Packages": {
        "$path": "Packages"
      }
    },
    "ServerStorage": {
      "$ignoreUnknownInstances": true,
      "$path": "src/ServerStorage"
    },
    "StarterPlayer": {
      "$properties": {
        "AutoJumpEnabled": false,
        "CameraMaxZoomDistance": 128.0,
        "GameSettingsAvatar": "R6",
        "UserEmotesEnabled": false
      }
    },
    "Teams": {
      "$ignoreUnknownInstances": true,
      "$path": "src/Teams"
    }
  }
}